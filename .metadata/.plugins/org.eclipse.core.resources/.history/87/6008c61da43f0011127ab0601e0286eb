package com.example.service;

import java.sql.ResultSet;
import java.sql.SQLException;
import java.util.ArrayList;
import java.util.List;

import org.springframework.stereotype.Service;

import com.example.bean.MemberBean;
import com.example.util.SqlUtil;

/**
 * @author kazuki_sawada
 * Serviceクラス
 */
@Service
public class MemberService {

	public List<MemberBean> getAll() {

		List<MemberBean> memberList=new ArrayList<MemberBean>();
		String sql="SELECT"
				+ "	tm.member_id"
				+ "	, tm.member_name"
				+ "	, tm.age"
				+ "	, tm.sex_flg"
				+ "	, tm.address"
				+ "	, tm.telephone"
				+ "	, tm.mail"
				+ "	, mp.position_name"
				+ "	, mp2.place_name"
				+ "FROM"
				+ "	tbl_member tm"
				+ "LEFT JOIN mst_position mp ON"
				+ "	tm.position_id = mp.position_id"
				+ "	AND mp.delete_flg = 0"
				+ "LEFT JOIN mst_place mp2 ON"
				+ "	tm.place_id = mp2.place_id"
				+ "	AND mp2.delete_flg = 0"
				+ "WHERE"
				+ "	tm.delete_flg = 0"
				+ "ORDER BY"
				+ "	tm.member_id";
		try {
			SqlUtil s = SqlUtil.getInstance("docker","docker");
			ResultSet resultSet=s.executeSelect(sql);
			while(resultSet.next()) {
				MemberBean bean =new MemberBean();

				bean.setMemberId(resultSet.getString("member_id"));
				bean.setName(resultSet.getString("member_name"));
				bean.setAge(resultSet.getString("age"));
				bean.setAddress(resultSet.getString("address"));
				bean.setSex(resultSet.getString("sex"));
				bean.setMail(resultSet.getString("mail"));
				bean.setTel(resultSet.getString("tel"));
				bean.setPositionId(resultSet.getString("position_id"));
				bean.setPositionName(resultSet.getString("positionName"));
				bean.setPlaceId(resultSet.getString("placeId"));
				bean.setPlaceName(resultSet.getString("placeName"));

				memberList.add(bean);
			}

		} catch (SQLException e) {
			e.printStackTrace();
		}
		return memberList;
	}
}
